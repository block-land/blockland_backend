PORT=3001
# Supabase PostgreSQL connection string. Docker Compose passes this to backend.
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
BETTER_AUTH_SECRET=your_super_secret_key_minimum_32_characters
BETTER_AUTH_URL=http://localhost:3001
REDIS_URL=redis://127.0.0.1:6379
# Comma-separated browser origins permitted to call this API.
CORS_ORIGINS=http://localhost:3000,http://blockland.app,https://blockland.app


# Blockland Solana
# Cluster: "devnet" | "mainnet-beta" (default: devnet)
SOLANA_CLUSTER=devnet
# RPC endpoint for the active cluster (devnet example below)
SOLANA_RPC_URL=https://api.devnet.solana.com
# On-chain addresses for the deployed tree/collection (devnet defaults shown)
MERKLE_TREE=89A62B9Bn45Nofa5CQXFUdyPPuo5Eth3rJkB288XWWGz
COLLECTION_MINT=FAtKx1TCQ9HZzoEfpo8DGatb9s6qUypQXJ7UvZWS1zSc
TREASURY=4JDGwFWszhntY6N47r2u7QFjGRqeG8A8Pc3wgUkVY1mX
# Admin keypair as inline JSON byte array (used in Docker). For local dev,
# ADMIN_WALLET_PATH may point to a keypair file instead.
ADMIN_WALLET_JSON=
